APP_NAME=EduConnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=oracle
DB_TNS=educonnectdb_low
DB_USERNAME=educonnect
DB_PASSWORD=
DB_CHARSET=AL32UTF8
TNS_ADMIN=/absolute/path/outside/repository/oracle/wallets/educonnect

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file
